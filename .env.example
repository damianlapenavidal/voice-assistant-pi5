OPENAI_API_KEY=your-key-here

# Optional: override the Realtime model (default: gpt-realtime-mini)
# REALTIME_MODEL=gpt-realtime-mini

# Optional: assistant voice (default: alloy)
# REALTIME_VOICE=alloy

# Optional: ALSA devices (auto-detected if omitted)
# AUDIO_INPUT_DEVICE=plughw:2,0
# AUDIO_OUTPUT_DEVICE=plughw:3,0

# Optional tuning (thresholds adapt from calibration — these are minor tweaks only)
# VOICE_DEBUG=1
# CALIBRATION_QUIET_SEC=1.0
# CALIBRATION_SPEAK_SEC=3.5
